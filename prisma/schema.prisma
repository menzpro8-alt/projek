// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Question {
  id          String   @id @default(cuid())
  subject     String   // e.g., s5 or Bahasa Inggris
  grade       String   // e.g., c1 or Kelas VII
  topic       String   // e.g., Tenses
  difficulty  String   // mudah, sedang, sulit
  type        String   // pilihan_ganda, essay, dll
  
  // Storing the full JSON payload generated by AI
  // This allows flexibility for different question types (options, matching pairs, etc.)
  content     Json     

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Keep User model for future auth
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}